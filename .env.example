# HBCE IPR Onboarding App
# Environment variables template.
# Do not store production secrets in this repository.

# Public app metadata
NEXT_PUBLIC_APP_NAME="HBCE IPR Onboarding App"
NEXT_PUBLIC_ORG_NAME="HERMETICUM B.C.E. S.r.l."
NEXT_PUBLIC_JOKER_C2_GATEWAY_URL="https://hbce-ai-joker-c2.vercel.app/interface"

# Runtime mode
HBCE_APP_ENV="local"
HBCE_MVP_MODE="true"
HBCE_FAIL_CLOSED_MODE="true"

# Future authentication layer
JWT_SECRET=""
SESSION_SECRET=""
SESSION_COOKIE_NAME="hbce_ipr_onboarding_session"

# Future database layer
DATABASE_URL=""

# Future protected document storage layer
DOCUMENT_STORAGE_BUCKET=""
DOCUMENT_STORAGE_REGION=""
DOCUMENT_STORAGE_ACCESS_KEY_ID=""
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=""

# Future protected media storage layer
MEDIA_STORAGE_BUCKET=""
MEDIA_STORAGE_REGION=""
MEDIA_STORAGE_ACCESS_KEY_ID=""
MEDIA_STORAGE_SECRET_ACCESS_KEY=""

# Future identity verification provider
IDENTITY_PROVIDER_NAME=""
IDENTITY_PROVIDER_API_URL=""
IDENTITY_PROVIDER_API_KEY=""

# Future document verification provider
DOCUMENT_VERIFICATION_PROVIDER_NAME=""
DOCUMENT_VERIFICATION_API_URL=""
DOCUMENT_VERIFICATION_API_KEY=""

# Future photo/video or liveness verification provider
LIVENESS_PROVIDER_NAME=""
LIVENESS_PROVIDER_API_URL=""
LIVENESS_PROVIDER_API_KEY=""

# Future HBCE EVT integration
EVT_REGISTRY_ENDPOINT=""
EVT_REGISTRY_API_KEY=""

# Future HBCE OPC integration
OPC_ENDPOINT=""
OPC_API_KEY=""

# Future revocation registry
REVOCATION_REGISTRY_ENDPOINT=""
REVOCATION_REGISTRY_API_KEY=""

# Future JOKER-C2 bridge
JOKER_C2_GATEWAY_URL="https://hbce-ai-joker-c2.vercel.app/interface"
JOKER_C2_BRIDGE_SECRET=""

# Security notes
# Never commit real API keys.
# Never commit real database credentials.
# Never commit real storage credentials.
# Never commit real identity documents.
# Never commit real fiscal identifiers.
# Never commit real photos, videos or biometric material.
# Never commit production onboarding records.
# Never commit private keys or operational certificates.
